<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617">

    <!-- TOP GLOW -->

    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/bg_splash_glow"
        android:alpha="0.25"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="-120dp"/>

    <!-- CENTER CONTENT -->

    <LinearLayout
        android:id="@+id/contentSplash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LOGO -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:cardCornerRadius="42dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E293B"
            app:cardBackgroundColor="#0F172A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/logoSplash"
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerInside"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nodo Cívico"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="38sp"
            android:letterSpacing="0.02"
            android:layout_marginTop="28dp"/>

        <!-- SUBTITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Community Reporting"
            android:textColor="#94A3B8"
            android:textSize="15sp"
            android:layout_marginTop="6dp"/>

        <!-- BLUE LINE -->

        <View
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:layout_marginTop="24dp"
            android:background="#2563EB"/>

    </LinearLayout>

    <!-- BOTTOM -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="34dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="#2563EB"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicializando sistema"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:layout_marginTop="14dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>